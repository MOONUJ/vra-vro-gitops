            "display-name": "Scriptable task",
            "script": {
                "value": "for each(var instance in machineInstance){\n    var config = Server.createConfigurationElement(configurationPath,instance.name);\n    config.setAttributeWithKey(\"cpu\",Number(instance.cpu), String(\"number\"));\n    config.setAttributeWithKey(\"memory\",Number(instance.memory), String(\"number\"));\n    config.setAttributeWithKey(\"gpuModel\",String(instance.gpuModel), String(\"string\"));\n    config.setAttributeWithKey(\"gpuSize\",String(instance.gpuSize), String(\"string\"));\n    config.setAttributeWithKey(\"gpuProfile\",String(instance.gpuProfile), String(\"string\"));\n    config.setAttributeWithKey(\"deviceCount\",String(instance.deviceCount), String(\"number\"));\n    config.setAttributeWithKey(\"vcsa_cluster\",String(instance.vcsa_cluster), String(\"Array/string\"));\n}",
                "encoded": false
            },
            "in-binding": {
                "bind": [
                    {
                        "name": "configurationPath",
                        "type": "string",
                        "export-name": "configurationPath"
                    },
                    {
                        "name": "machineInstance",
                        "type": "Array/CompositeType(name:string,cpu:number,memory:number,gpuModel:string,gpuSize:string,gpuProfile:string,deviceCount:number,vcsa_cluster:Array/string):gpuMachineInstance",
                        "export-name": "machineInstance"
                    }
