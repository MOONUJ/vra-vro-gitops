    "source": "# -*- coding: utf-8 -*-\n'''\n@copyright: Equal Plus\n@author: Hye-Churn Jang\n'''\n\n#===============================================================================\n# Import Libraries Here\n#===============================================================================\nimport json\nimport time\n\n\n#===============================================================================\n# AaManager SDK\n#===============================================================================\nclass AaManager:\n    def __init__(self, context): self.context = context\n    def toJson(self, response):\n        if response['status'] >= 400: raise Exception(response['content'].decode('utf-8'))\n        try: return json.loads(response['content'].decode('utf-8'))\n        except: return response['content'].decode('utf-8')\n    def encode(self, url): return url.replace(' ', '%20').replace('$', '%24').replace(\"'\", '%27').replace('[', '%5B').replace(']', '%5D')\n    def get(self, url): return self.toJson(self.context.request(operation='GET', link=self.encode(url), body=''))\n    def post(self, url, data): return self.toJson(self.context.request(operation='POST', link=self.encode(url), body=data))\n    def put(self, url, data): return self.toJson(self.context.request(operation='PUT', link=self.encode(url), body=data))\n    def patch(self, url, data): return self.toJson(self.context.request(operation='PATCH', link=self.encode(url), body=data))\n    def delete(self, url, data=''): return self.toJson(self.context.request(operation='DELETE', link=self.encode(url), body=data))\n    def getUerp(self, url): return self.get(f'/provisioning/uerp{url}')\n    def postUerp(self, url, data): return self.post(f'/provisioning/uerp{url}', data)\n    def putUerp(self, url, data): return self.put(f'/provisioning/uerp{url}', data)\n    def patchUerp(self, url, data): return self.patch(f'/provisioning/uerp{url}', data)\n    def deleteUerp(self, url, data=''): return self.delete(f'/provisioning/uerp{url}', data)\n    def runOrchAction(self, projectId, uri, data={}):\n        result = self.post(f'/form-service/api/forms/renderer/external-value?projectId={projectId}', {'uri':uri, 'dataSource':'scriptAction', 'parameters':[{'name':k, 'value':v} for k, v in data.items()]})\n        if 'data' in result: return result['data']\n        elif 'error' in result: raise Exception(result['error']['summaryMessage'])\n        else: raise Exception('unknown error')\n\n\n#===============================================================================\n# Implement Handler Here\n#===============================================================================\ndef handler(context, inputs):\n    aa = AaManager(context)\n\n    if 'administrators' not in inputs: inputs['administrators'] = []\n    if 'members' not in inputs: inputs['members'] = []\n    if 'viewers' not in inputs: inputs['viewers'] = []\n    if 'supervisors' not in inputs: inputs['supervisors'] = []\n    if 'sharedResources' not in inputs: inputs['sharedResources'] = False\n    if 'cloudZones' not in inputs: inputs['cloudZones'] = []\n    if 'placementPolicy' not in inputs: inputs['placementPolicy'] = 'default'\n    if 'catalogs' not in inputs: inputs['catalogs'] = []\n    if 'organization' not in inputs: inputs['organization'] = []\n    \n    project = aa.post('/iaas/api/projects', {\n        'name': inputs['name'],\n        'description': inputs['displayName'],\n        'sharedResources': inputs['sharedResources'],\n        'zoneAssignmentConfigurations': [{'zoneId': cloudZone} for cloudZone in inputs['cloudZones']],\n        'placementPolicy': inputs['placementPolicy'].upper(),\n        'customProperties': {\n            'profile': inputs['profile'],\n            'organization': inputs['organization']\n        }   \n    })\n    projectId = project['id']\n    \n    principals = []\n    for username in inputs['administrators']: principals.append({\n        'email': username,\n        'role': 'administrator',\n        'type': 'user'\n    })\n    for username in inputs['members']: principals.append({\n        'email': username,\n        'role': 'member',\n        'type': 'user'\n    })\n    for username in inputs['viewers']: principals.append({\n        'email': username,\n        'role': 'viewer',\n        'type': 'user'\n    })\n    for username in inputs['supervisors']: principals.append({\n        'email': username,\n        'role': 'supervisor',\n        'type': 'user'\n    })\n    aa.patch(f'/project-service/api/projects/{projectId}/principals', {\n        'modify': principals\n    })\n\n    if inputs['catalogs']:\n        inputs['catalogPolicy'] = aa.post('/policy/api/policies', {\n            'name': inputs['name'] + '-catalog',\n            'projectId': projectId,\n            'enforcementType': 'HARD',\n            'typeId': 'com.vmware.policy.catalog.entitlement',\n            'definition': {\n                'entitledUsers': [{\n                    'userType': 'USER',\n                    'principals': [{\n                        'type': 'PROJECT',\n                        'referenceId': ''\n                    }],\n                    'items': [{\n                        'id': catalogId,\n                        'type': 'CATALOG_ITEM_IDENTIFIER'\n                    } for catalogId in inputs['catalogs']]\n                }]\n            }\n        })['id']\n    else: inputs['catalogPolicy'] = ''\n    \n    if inputs['approver'] and inputs['supervisors'] and inputs['approvalActions']:\n        approver = inputs['approver']\n        inputs['approvalPolicy'] = aa.post('/policy/api/policies', {\n            'name': inputs['name'] + '-approval',\n            'projectId': projectId,\n            'enforcementType': 'HARD',\n            'typeId': 'com.vmware.policy.approval',\n            'definition': {\n                'level': 1,\n                'approverType': 'USER',\n                'approvalMode': 'ANY_OF',\n                'approvers': [f'USER:{approver}'],\n                'autoApprovalDecision': inputs['autoApprovalDecision'] if 'autoApprovalDecision' in inputs and inputs['autoApprovalDecision'] else 'REJECT',\n                'autoApprovalExpiry': inputs['autoApprovalExpiry'] if 'autoApprovalExpiry' in inputs and inputs['autoApprovalExpiry'] else 1,\n                'actions': inputs['approvalActions']\n            }\n        })['id']\n    else: inputs['approvalPolicy'] = ''\n\n    if not aa.getUerp(f\"/resources/tags?expand&$filter=((key eq 'projectId') and (value eq '{projectId}'))\")['documentLinks']:\n        aa.postUerp('/resources/tags?expand', {\n            'key': 'projectId',\n            'value': projectId,\n            'isSaved': True,\n            'origins': ['USER_DEFINED']\n        })\n    # default vpc, subnet provisioin\n    additionalDeploymentIds = []\n    if 'createDefaultDeployments' not in inputs: inputs['createDefaultDeployments'] = False\n    if inputs['createDefaultDeployments'] == True:\n        vpcDeploymentIds = []\n        subnetDeploymentIds = []\n        vpcCatalogItemId = aa.get(\"/catalog/api/items?search=ClovirONE_Virtual Private Cloud\")['content'][0]['id']\n        subnetCatalogItemId = aa.get(\"/catalog/api/items?search=ClovirONE_Segment&$orderby=name\")['content'][0]['id']\n        status_count = 0\n        max_retries = 30  # 최대 재시도 횟수\n        status_check = True\n    \n        while status_check:\n            try:\n                itemProjects = aa.get(f\"/catalog/api/items/{vpcCatalogItemId}\")['projectIds']\n    \n                for itemProject in itemProjects:\n                    if itemProject == projectId:\n                        status_check = False  # 프로젝트 확인되면 루프 종료\n                        break\n    \n                if not status_check:\n                    break\n    \n                if status_count >= max_retries:\n                    raise TimeoutError(\"Status Check Timeout\")\n    \n                status_count += 1\n                print(f\"Catalog item project check retry.. {status_count}\")\n                time.sleep(10)  # 10초 대기\n    \n            except Exception as e:\n                raise RuntimeError(f\"Error: {e}\")\n        # vpc input 변수 설정\n        metadata_catalog = \"VPC\";\n        metadata_main_catalog = \"Network\";\n        metadata_available = \"vpc member\";\n        managed_network_cidr = \"172.31.255.0/24\";\n        metadata_resource_type = \"Custom.VPC\";\n        # vpc provision\n        for cloudZoneId in inputs['cloudZones']:\n            placementZoneLink = f\"/provisioning/resources/placement-zones/{cloudZoneId}\"\n            vpcInfraProfileLinkArray = aa.runOrchAction(projectId, \"com.bvp.bp.vpc/getVpcInfraProfilesByPlacementZoneLink\",{\"placementZoneLink\": placementZoneLink })\n            for vpcInfraProfileLink in vpcInfraProfileLinkArray:\n                vpcInfraId = aa.runOrchAction(projectId, \"com.bvp.bp.vpc/getVpcInfraIdByProfileLink\", {\"profileLink\": vpcInfraProfileLink['value']})\n                codeName = aa.runOrchAction(projectId,\"com.bvp.bp.vpc/getRandomString\",{\"type\" : \"lowerDigit\", \"length\": \"8\"})\n                deploymentName = \"VPC: \" + project['name'] + \"-\" + codeName\n                displayName = project['description'] + \" \" + vpcInfraProfileLink['label'].split()[-1] \n                catalogVersion = aa.get(f\"/catalog/api/items/{vpcCatalogItemId}/versions\")['content'][0]['id'];\n                vpcResult = aa.post(f\"/catalog/api/items/{vpcCatalogItemId}/request\",{\n                    \"projectId\": projectId,\n                    \"version\": catalogVersion,\n                    \"deploymentName\" : deploymentName,\n                    \"inputs\": {\n                        \"codeName\" : codeName,\n                        \"_project_id\" : projectId,\n                        \"displayName\": displayName,\n                        \"_project_name\" : project['name'],\n                        \"_vpc_infra_id\" : vpcInfraId,\n                        \"placementZone\" : placementZoneLink,\n                        \"requestMessage\": \"default create vpc\",\n                        \"vpcInfraProfile\" : vpcInfraProfileLink['value'],\n                        \"_metadata_catalog\" : metadata_catalog,\n                        \"metadata_main_catalog\" : metadata_main_catalog,\n                        \"_metadata_available\" : metadata_available,\n                        \"_managed_network_cidr\" : managed_network_cidr,\n                        \"_metadata_resource_type\" : metadata_resource_type,\n                        }\n                });\n                vpcDeploymentIds.append(vpcResult[0]['deploymentId'])\n                additionalDeploymentIds.append(vpcResult[0]['deploymentId'])\n                \n        num = 0\n        for vpcDeploymentId in vpcDeploymentIds:\n            status_check = True\n            status_count = 0\n            while status_check:\n                try:\n                    if aa.get(f\"/deployment/api/deployments/{vpcDeploymentId}\")['status'] == \"CREATE_SUCCESSFUL\":\n                        status_check = False\n                        break\n                    if status_count >= max_retries:\n                        raise TimeoutError(\"Status Check Timeout\")\n                    status_count += 1\n                    print(f\"VPC Deployment check retry.. {status_count}\")\n                    time.sleep(10)  # 10초 대기\n                except Exception as e:\n                    raise RuntimeError(f\"Error: {e}\")\n    \n            catalogVersion = aa.get(f\"/catalog/api/items/{subnetCatalogItemId}/versions\")['content'][0]['id'];\n            codeName = aa.runOrchAction(projectId,\"com.bvp.bp.vpc/getRandomString\",{\"type\" : \"lowerDigit\", \"length\": \"8\"})\n            vpc = aa.get(f\"/deployment/api/deployments/{vpcDeploymentId}/resources?names=vpc\")['content'][0]\n            vpcProperties = vpc['properties']\n            cidr = f\"10.100.10{num}.0/24\"\n            deploymentName = \"SEG: \" + vpcProperties['name'] + \"-\" + cidr\n            subnetResult = aa.post(f\"/catalog/api/items/{subnetCatalogItemId}/request\",{\n                \"projectId\": projectId,\n                \"version\": catalogVersion,\n                \"deploymentName\" : deploymentName,\n                \"inputs\": {\n                    \"codeName\" : codeName,\n                    \"_project_id\" : projectId,\n                    \"displayName\": f\"{vpcProperties['displayName']} Subnet\",\n                    \"vpc\" : vpcProperties['vpcProfile'],\n                    \"_vpc_id\" : vpcProperties['id'],\n                    \"_vpc_name\" : vpcProperties['name'],\n                    \"requestMessage\": \"Default Create Subnet\",\n                    \"_metadata_catalog\" : \"Segment\",\n                    \"metadata_main_catalog\" : \"Network\",\n                    \"_metadata_available\" : \"vpc member\",\n                    \"cidr\" : cidr,\n                    \"_metadata_resource_type\" : \"Cloud.NSX.Network\",\n                }\n            });\n            subnetDeploymentIds.append(subnetResult[0]['deploymentId'])\n            additionalDeploymentIds.append(subnetResult[0]['deploymentId'])\n            vpcId = vpc['id']\n            aa.post(f\"/deployment/api/resources/{vpcId}/requests\",{\"actionId\": \"Custom.VPC.custom.appendadditionaldeploymentids\", \"inputs\": {\"additionalDeploymentIds\" : [subnetResult[0]['deploymentId']]}})\n            num += 1\n        \n        for subnetDeploymentId in subnetDeploymentIds:\n            status_check = True\n            status_count = 0\n            while status_check:\n                try:\n                    if aa.get(f\"/deployment/api/deployments/{subnetDeploymentId}\")['status'] == \"CREATE_SUCCESSFUL\":\n                        status_check = False\n                        break\n                    if status_count >= max_retries:\n                        raise TimeoutError(\"Status Check Timeout\")\n                    status_count += 1\n                    print(f\"VPC Deployment check retry.. {status_count}\")\n                    time.sleep(10)  # 10초 대기\n                except Exception as e:\n                    raise RuntimeError(f\"Error: {e}\")\n\n\n    inputs['id'] = projectId\n    inputs['selfId'] = projectId\n    inputs['additionalDeploymentIds'] = additionalDeploymentIds\n    outputs = inputs\n    return outputs\n",
